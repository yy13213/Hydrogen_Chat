# ============================================================
# Deep Research 框架环境变量配置
# 复制此文件为 .env 并填写实际值
# ============================================================

# Gemini API Key（用于所有 Gemini 模型调用）
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini API 代理地址（指向本地转发端口，即 Google_ai2dify_port6773.py 的地址）
GEMINI_BASE_URL=http://localhost:6773

# DeepSeek API Key（仅用于 Publisher 最终整理）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 主模型名称
GEMINI_MODEL=gemini-3.1-pro-preview

# Deep Research 服务端口
DEEP_RESEARCH_PORT=3031

# 项目数据存储根目录
PROJECTS_DIR=projects
