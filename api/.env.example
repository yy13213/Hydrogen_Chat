# Hydrogen Chat API 环境变量配置模板
# 复制此文件为 .env 并填入实际的配置值

# ========================================
# Google Gemini API 配置
# ========================================
# 获取 API Key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ========================================
# vLLM Reranker 服务配置
# ========================================
# Reranker 服务转发目标地址
VLLM_API_URL=http://127.0.0.1:9582/v1/completions

# ========================================
# 服务端口配置
# ========================================
# Google AI 服务端口
GOOGLE_AI_PORT=6773

# Reranker 服务端口
RERANKER_PORT=9583

