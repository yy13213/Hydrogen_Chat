SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=sqlite:///openclaw_webapp.db

APP_BRAND=OpenClaw Portal

OPENCLAW_BASE_URL=http://127.0.0.1:18789
# Optional now: the project has a built-in default token in app/config.py.
OPENCLAW_GATEWAY_TOKEN=33fdab2ebec3494dd0ed21dd67ae69f68538fb367b6506e4
OPENCLAW_DEFAULT_AGENT=main
OPENCLAW_ALLOWED_AGENTS=main,hydrogen
OPENCLAW_MAX_CONCURRENT=4
OPENCLAW_MODEL=openclaw
OPENCLAW_TIMEOUT=180
OPENCLAW_CONNECT_TIMEOUT=10
OPENCLAW_READ_TIMEOUT=180
OPENCLAW_RETRY_TIMES=2
OPENCLAW_RETRY_BACKOFF=1.0
# ============================================================
# Hydrogen Chat 环境变量配置模板
# 复制此文件为 .env 并填入实际值，.env 不会被提交到 git
# ============================================================

# ── Gemini 代理服务 ──────────────────────────────────────────
# 本地代理服务地址（运行 api/Google_ai2dify_port6773.py 后生效）
GEMINI_BASE_URL=http://localhost:6773

# Google Gemini API Key（从 https://aistudio.google.com/app/apikey 获取）
GEMINI_API_KEY=xxx

# ── 模型配置 ─────────────────────────────────────────────────
# 主聊天模型
CHAT_MODEL=gemini-3.1-pro-preview-customtools

# SQL 生成模型（用于数据库查询工具）
SQL_MODEL=gemini-3.1-pro-preview-customtools

# 标题生成模型（用于历史对话自动命名）
TITLE_MODEL=gemini-3.1-flash-lite-preview

# ── Tavily 网络搜索 ──────────────────────────────────────────
# 从 https://app.tavily.com 获取
TAVILY_API_KEY=tvly-dev-xxx

# ── 知识库服务 ───────────────────────────────────────────────
# 本地知识库 Webhook 地址
KNOWLEDGE_BASE_URL=http://localhost:6772/triggers/webhook-debug/xxx
