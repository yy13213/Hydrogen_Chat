# Hydrogen Chat API 环境变量配置模板
# 复制此文件为 .env 并填入实际的配置值

# ========================================
# Google Gemini API 配置
# ========================================
# 获取 API Key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ========================================
# vLLM Reranker 服务配置
# ========================================
# Reranker 服务转发目标地址
VLLM_API_URL=http://127.0.0.1:9582/v1/completions

# ========================================
# 服务端口配置
# ========================================
# Google AI 服务端口
GOOGLE_AI_PORT=6773

# Reranker 服务端口
RERANKER_PORT=9583

# ========================================
# 高并发性能配置（Google AI 服务）
# ========================================
# 工作进程数（建议设置为 CPU 核心数，如 4、8、16）
WORKERS=4

# 连接池配置
MAX_CONNECTIONS=500  # 最大连接数
MAX_KEEPALIVE_CONNECTIONS=100  # 保持活动的连接数

# 超时配置（秒）
CONNECT_TIMEOUT=10.0  # 连接超时
READ_TIMEOUT=120.0  # 读取超时
POOL_TIMEOUT=10.0  # 连接池超时

# 并发限制
MAX_CONCURRENT_REQUESTS=1000  # 最大并发请求数

